{
  "name": "ssq-data-lab",
  "version": "1.0.0",
  "private": true,
  "description": "双色球历史数据可视化与加权随机号码生成器（纯静态站点）",
  "type": "module",
  "scripts": {
    "serve": "python -m http.server 5173",
    "test": "node --test tests/*.test.mjs",
